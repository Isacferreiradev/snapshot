# Server
PORT=3001

# Your base URL — no trailing slash
# Local development:
BASE_URL=http://localhost:3001
# Production (Railway, etc.):
# BASE_URL=https://your-app.up.railway.app

# Stripe keys — find these at https://dashboard.stripe.com/apikeys
# Use sk_test_... and pk_test_... for development
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — run `stripe listen` and copy the "whsec_..." value printed
# In production, copy from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription price IDs — create recurring prices in https://dashboard.stripe.com/products
# Starter: R$19,90/mês — 50 capturas/mês
STRIPE_PRICE_STARTER=price_...
# Pro: R$49,90/mês — capturas ilimitadas + comparação A/B
STRIPE_PRICE_PRO=price_...
# Agency: R$129,90/mês — tudo do Pro + API + múltiplos códigos
STRIPE_PRICE_AGENCY=price_...

# Admin panel password — set a strong secret value
ADMIN_PASSWORD=changeme
