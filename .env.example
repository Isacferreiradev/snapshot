# ─── AbacatePay — Checkout Transparente PIX ─────────────────────────────────
# Chave da API — app.abacatepay.com/settings/api
# Desenvolvimento: abc_dev_...  |  Produção: abc_live_...
ABACATEPAY_API_KEY=abc_dev_XYA2ppqTWYz53xMaAyBZj200

# Secret do webhook — gerado ao criar endpoint em app.abacatepay.com/webhooks
# Endpoint a cadastrar: https://seu-dominio.com.br/api/webhook/abacatepay
# Eventos a selecionar: pix.paid
ABACATEPAY_WEBHOOK_SECRET=

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
BASE_URL=http://localhost:3001
NODE_ENV=development

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=


# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://e1b31e329b6b83fa6e77aa8ae98f70f4@o4511063161307136.ingest.us.sentry.io/4511063164125184

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Resend — Emails Transacionais ───────────────────────────────────────────
# Chave da API do Resend — resend.com/api-keys
RESEND_API_KEY=
# Remetentes (domínio deve estar verificado no Resend)
EMAIL_FROM_MAIN=contato@snapdeck.pro
EMAIL_FROM_SUPPORT=suporte@snapdeck.pro
EMAIL_FROM_NOREPLY=noreply@snapdeck.pro
